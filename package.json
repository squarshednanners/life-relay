{
  "name": "liferelay",
  "version": "2.0.0",
  "type": "module",
  "description": "Privacy-first, offline-capable web app for organizing estate plans, digital assets, and critical information.",
  "homepage": "https://liferelay.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/squarshednanners/life-relay.git"
  },
  "bugs": {
    "url": "https://github.com/squarshednanners/life-relay/issues"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "test": "vitest"
  },
  "dependencies": {
    "dexie": "^3.2.4",
    "pdf-lib": "^1.17.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.5",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^1.3.1",
    "vue-tsc": "^3.1.8"
  }
